<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Styles.Resources>
        <CornerRadius x:Key="ControlCornerRadius">2</CornerRadius>
        <CornerRadius x:Key="ControlCornerRadiusLarge">2</CornerRadius>
        <CornerRadius x:Key="CardCornerRadius">2</CornerRadius>
        <Thickness x:Key="ControlBorderThickness">1</Thickness>
        <Thickness x:Key="ControlPadding">10,5</Thickness>
        <x:Double x:Key="ControlHeight">28</x:Double>
        <x:Double x:Key="ControlFontSize">13</x:Double>
        <BoxShadows x:Key="CardShadow">0 0 0 0 #00000000</BoxShadows>
    </Styles.Resources>

    <StyleInclude Source="avares://Z21Sniffer.UI.Desktop/Themes/Skins/Skin.Shared.axaml"/>
