<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Z21Sniffer.Presentation.ViewModels;assembly=Z21Sniffer.Presentation"
             xmlns:model="clr-namespace:Z21Sniffer.Core.Model;assembly=Z21Sniffer.Core"
             xmlns:controls="clr-namespace:Z21Sniffer.UI.Desktop.Controls"
             xmlns:conv="clr-namespace:Z21Sniffer.UI.Desktop.Converters"
             xmlns:views="clr-namespace:Z21Sniffer.UI.Desktop.Views"
             x:Class="Z21Sniffer.UI.Desktop.Views.WorkspaceView"
             x:DataType="vm:WorkspaceViewModel"
             Background="{DynamicResource BackgroundBrush}">

  <UserControl.Resources>
    <conv:KindToBrushConverter x:Key="KindToBrush" />
    <conv:KindToLocalizedConverter x:Key="KindToLocalized" />
  </UserControl.Resources>

  <UserControl.DataTemplates>
    <DataTemplate DataType="vm:SensorLegendContentViewModel">
      <views:SensorLegendContentView />
    </DataTemplate>
    <DataTemplate DataType="vm:ConnectionLegendContentViewModel">
      <views:ConnectionLegendContentView />
    </DataTemplate>
    <DataTemplate DataType="vm:LocoLegendContentViewModel">
      <views:LocoLegendContentView />
    </DataTemplate>
    <DataTemplate DataType="vm:TrackPowerLegendContentViewModel">
      <views:TrackPowerLegendContentView />
    </DataTemplate>
    <DataTemplate DataType="vm:SystemCurrentLegendContentViewModel">
      <views:SystemCurrentLegendContentView />
    </DataTemplate>
  </UserControl.DataTemplates>

  <UserControl.Styles>
    <Style Selector="TextBlock.faultMessage">
      <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Ellipse.statusDot">
      <Setter Property="Fill" Value="{DynamicResource DangerBrush}" />
    </Style>
    <Style Selector="Ellipse.statusDot.connected">
      <Setter Property="Fill" Value="{DynamicResource PrimaryBrush}" />
    </Style>
    <Style Selector="Button.caption">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Width" Value="46" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.caption /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="Button.caption:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource ControlHoverBrush}" />
    </Style>
    <Style Selector="Button.caption.close:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
    </Style>
    <Style Selector="Button.caption Path">
      <Setter Property="Stroke" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="StrokeThickness" Value="1" />
    </Style>
    <Style Selector="Button.caption.close:pointerover Path">
      <Setter Property="Stroke" Value="{DynamicResource PrimaryForegroundBrush}" />
    </Style>
  </UserControl.Styles>

  <Panel>
  <DockPanel>

    <Border DockPanel.Dock="Top" Height="40" Background="{DynamicResource SurfaceBrush}"
            PointerPressed="OnTitleBarPressed">
      <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Stretch">
          <Button x:Name="MinimizeButton" Classes="caption" Click="OnMinimize"
                  ToolTip.Tip="{Binding Localization[Minimize]}">
            <Path Data="M0,5 L10,5" />
          </Button>
          <Button x:Name="MaximizeButton" Classes="caption" Click="OnMaximizeRestore">
            <Panel>
              <Path x:Name="MaximizeGlyph" Data="M0.5,0.5 L9.5,0.5 L9.5,9.5 L0.5,9.5 Z" />
              <Path x:Name="RestoreGlyph" Data="M2.5,0.5 L9.5,0.5 L9.5,7.5 M0.5,2.5 L7.5,2.5 L7.5,9.5 L0.5,9.5 Z"
                    IsVisible="False" />
            </Panel>
          </Button>
          <Button x:Name="CloseButton" Classes="caption close" Click="OnCloseWindow"
                  ToolTip.Tip="{Binding Localization[Close]}">
            <Path Data="M0,0 L10,10 M0,10 L10,0" />
          </Button>
        </StackPanel>
        <WrapPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
          <Button Content="⚙" Command="{Binding OpenSettingsCommand}" ToolTip.Tip="{Binding Localization[Settings]}" Margin="0,0,12,0" />
          <Button Command="{Binding Connection.ToggleConnectionCommand}" MinWidth="92" Margin="0,0,12,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <Ellipse Classes="statusDot" Classes.connected="{Binding Connection.IsConnected}" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0" />
              <TextBlock Text="{Binding Connection.ToggleLabel}" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button Content="{Binding Recording.ToggleLabel}" Command="{Binding Recording.ToggleCommand}" />
          <Border Width="1" Height="20" VerticalAlignment="Center" Background="{DynamicResource BorderBrush}" Margin="8,0" />
          <controls:RangeInputBox MinValue="{Binding Timeline.HighlightMinSeconds, Mode=TwoWay}"
                                  MaxValue="{Binding Timeline.HighlightThresholdSeconds, Mode=TwoWay}"
                                  Unit="{Binding Localization[UnitSeconds]}"
                                  Separator="{Binding Localization[RangeSeparator]}"
                                  ToolTip.Tip="{Binding Localization[HighlightBandTooltip]}"
                                  VerticalAlignment="Center" />
          <Border Width="1" Height="20" VerticalAlignment="Center" Background="{DynamicResource BorderBrush}" Margin="8,0" />
          <Button Content="{Binding Localization[Session]}" Click="OnSessionMenu" />
        </WrapPanel>
      </DockPanel>
    </Border>

    <Grid>
    <TabControl>
      <TabItem x:Name="TimelineTab" Header="{Binding Localization[TimelineTab]}">
        <!-- Negative margin cancels the TabControl template's 16px content inset so the timeline fills the tab edge-to-edge. -->
        <DockPanel Margin="-16">
          <ScrollBar x:Name="TimeScrollBar" DockPanel.Dock="Bottom" Orientation="Horizontal" Height="16"
                     Minimum="0" Scroll="OnTimeScroll" AllowAutoHide="False" />

          <Grid ColumnDefinitions="220,*">
            <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
              <ListBox x:Name="LegendList" ItemsSource="{Binding Timeline.LegendRows}">
                <ListBox.Styles>
                  <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="MinHeight" Value="26" />
                  </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:LegendRowViewModel">
                    <DockPanel Height="{Binding Height}" LastChildFill="True">
                      <TextBlock DockPanel.Dock="Left" Text="≡" VerticalAlignment="Center" Margin="2,0,6,0"
                                 Cursor="SizeAll" Foreground="{DynamicResource TextSecondaryBrush}"
                                 PointerPressed="OnDragHandlePressed" />
                      <ContentControl Content="{Binding Content}" />
                    </DockPanel>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Border>

            <DockPanel Grid.Column="1">
              <controls:TimeAxisControl DockPanel.Dock="Bottom" Height="18" DataContext="{Binding Timeline}" />
              <controls:FeedbackTimelineControl x:Name="BarsControl" DataContext="{Binding Timeline}" />
            </DockPanel>
          </Grid>
        </DockPanel>
      </TabItem>

      <TabItem Header="{Binding Localization[TrafficLog]}">
        <DockPanel Margin="-16">
          <StackPanel DockPanel.Dock="Top" Margin="12,10,12,8" Orientation="Horizontal" Spacing="6">
            <controls:MultiSelectDropDown VerticalAlignment="Center" Title="{Binding Localization[FilterTypes]}"
                                          ItemsSource="{Binding Log.KindToggles}" />
            <TextBox Width="220" Text="{Binding Log.SearchText}" Watermark="{Binding Localization[Search]}" />
          </StackPanel>

          <ListBox x:Name="LogList" ItemsSource="{Binding Log.Filtered}" SelectionMode="Multiple"
                   Margin="12,0,0,0" FontFamily="Consolas" Background="{DynamicResource BackgroundBrush}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="model:LogEntry">
                <Grid ColumnDefinitions="Auto,Auto,*" >
                  <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat='HH:mm:ss.fff'}"
                             Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
                  <Border Grid.Column="1" CornerRadius="3" Padding="6,1" Margin="0,0,10,0" MinWidth="78"
                          Background="{Binding Kind, Converter={StaticResource KindToBrush}}">
                    <TextBlock Text="{Binding Kind, Converter={StaticResource KindToLocalized}}"
                               Foreground="{DynamicResource PrimaryForegroundBrush}" FontSize="11" HorizontalAlignment="Center" />
                  </Border>
                  <TextBlock Grid.Column="2" Text="{Binding Message}" VerticalAlignment="Center"
                             Classes.faultMessage="{Binding Fault}" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </TabItem>
    </TabControl>
    <Button x:Name="RowsButton" Click="OnRowsMenu" Padding="10,4"
            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,5,6,0"
            Background="{DynamicResource SurfaceAltBrush}"
            BorderBrush="{DynamicResource BorderStrongBrush}" BorderThickness="1"
            IsVisible="{Binding #TimelineTab.IsSelected, FallbackValue=True}">
      <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
        <Path Data="M1,1 H13 L8.4,6.6 V12 L5.6,10.4 V6.6 Z" Width="13" Height="12" Stretch="Uniform"
              Fill="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
        <TextBlock Text="{Binding Localization[Rows]}" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
        <Path Data="M0,0 L8,0 L4,5 Z" Width="8" Height="5" Stretch="Uniform"
              Fill="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
      </StackPanel>
    </Button>
    </Grid>

  </DockPanel>
  <Canvas x:Name="GhostLayer" IsHitTestVisible="False" />
  </Panel>
</UserControl>
