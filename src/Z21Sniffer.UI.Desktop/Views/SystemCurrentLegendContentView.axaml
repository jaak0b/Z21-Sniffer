<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Z21Sniffer.Presentation.ViewModels;assembly=Z21Sniffer.Presentation"
             x:Class="Z21Sniffer.UI.Desktop.Views.SystemCurrentLegendContentView"
             x:DataType="vm:SystemCurrentLegendContentViewModel"
             ToolTip.Tip="{Binding Details}">
  <DockPanel Height="26" LastChildFill="True">
    <Path Classes="legendIcon" DockPanel.Dock="Left"
          Data="M1,13 L4,13 L6,4 L9,15 L11,9 L13,9" />
    <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
  </DockPanel>
</UserControl>
