<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Z21Sniffer.Presentation.ViewModels;assembly=Z21Sniffer.Presentation"
             x:Class="Z21Sniffer.UI.Desktop.Views.ConnectionLegendContentView"
             x:DataType="vm:ConnectionLegendContentViewModel"
             ToolTip.Tip="{Binding Details}">
  <DockPanel Height="26" LastChildFill="True">
    <Path Classes="legendIcon" DockPanel.Dock="Left"
          Data="M1,8 a2.4,2.4 0 1,0 4.8,0 a2.4,2.4 0 1,0 -4.8,0 Z M10.2,8 a2.4,2.4 0 1,0 4.8,0 a2.4,2.4 0 1,0 -4.8,0 Z M5,7.1 H11 V8.9 H5 Z" />
    <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
  </DockPanel>
</UserControl>
