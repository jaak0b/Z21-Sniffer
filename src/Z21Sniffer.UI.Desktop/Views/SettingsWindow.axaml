<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Z21Sniffer.Presentation.ViewModels;assembly=Z21Sniffer.Presentation"
        xmlns:loc="clr-namespace:Z21Sniffer.Presentation.Localization;assembly=Z21Sniffer.Presentation"
        xmlns:conv="clr-namespace:Z21Sniffer.UI.Desktop.Converters"
        x:Class="Z21Sniffer.UI.Desktop.Views.SettingsWindow"
        x:DataType="vm:WorkspaceViewModel"
        Title="{Binding Localization[Settings]}"
        Width="440" SizeToContent="Height"
        CanResize="False" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">

  <Window.Resources>
    <conv:EnumDisplayConverter x:Key="EnumDisplay" />
  </Window.Resources>

  <StackPanel Margin="18" Spacing="16">

    <TextBlock Text="{Binding Localization[Connection]}" FontWeight="SemiBold" />
    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" Margin="8,0,0,0">
      <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Localization[Source]}" VerticalAlignment="Center" Margin="0,0,10,6" />
      <ComboBox Grid.Row="0" Grid.Column="1" x:Name="SourceCombo" HorizontalAlignment="Stretch" Margin="0,0,0,6"
                SelectedItem="{Binding Connection.Source}" IsEnabled="{Binding Connection.CanEditConnection}" />
      <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Localization[Host]}" VerticalAlignment="Center" Margin="0,0,10,6"
                 IsVisible="{Binding Connection.ShowZ21Settings, FallbackValue=False}" />
      <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,6" Text="{Binding Connection.Host}"
               IsEnabled="{Binding Connection.CanEditConnection}"
               IsVisible="{Binding Connection.ShowZ21Settings, FallbackValue=False}" />
      <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding Localization[Port]}" VerticalAlignment="Center" Margin="0,0,10,0"
                 IsVisible="{Binding Connection.ShowZ21Settings, FallbackValue=False}" />
      <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Connection.Port}"
               IsEnabled="{Binding Connection.CanEditConnection}"
               IsVisible="{Binding Connection.ShowZ21Settings, FallbackValue=False}" />
    </Grid>

    <TextBlock Text="{Binding Localization[Appearance]}" FontWeight="SemiBold" />
    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" Margin="8,0,0,0">
      <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Localization[Theme]}" VerticalAlignment="Center" Margin="0,0,10,6" />
      <ComboBox Grid.Row="0" Grid.Column="1" x:Name="ThemeCombo" HorizontalAlignment="Stretch" Margin="0,0,0,6"
                ItemsSource="{Binding Theme.Themes}"
                SelectedItem="{Binding Theme.SelectedTheme, Mode=TwoWay}">
        <ComboBox.ItemTemplate>
          <DataTemplate x:DataType="vm:AppTheme">
            <TextBlock>
              <TextBlock.Text>
                <MultiBinding Converter="{StaticResource EnumDisplay}">
                  <Binding />
                  <Binding Source="{x:Static loc:LocalizationService.Instance}" Path="CurrentCode" />
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Localization[Language]}" VerticalAlignment="Center" Margin="0,0,10,0" />
      <ComboBox Grid.Row="1" Grid.Column="1" x:Name="LanguageCombo" HorizontalAlignment="Stretch"
                ItemsSource="{Binding Languages}"
                SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}">
        <ComboBox.ItemTemplate>
          <DataTemplate x:DataType="vm:AppLanguage">
            <TextBlock>
              <TextBlock.Text>
                <MultiBinding Converter="{StaticResource EnumDisplay}">
                  <Binding />
                  <Binding Source="{x:Static loc:LocalizationService.Instance}" Path="CurrentCode" />
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </Grid>

    <TextBlock Text="{Binding Localization[McpServer]}" FontWeight="SemiBold" />
    <StackPanel Orientation="Horizontal" Spacing="8" Margin="8,0,0,0">
      <CheckBox Content="{Binding Localization[Enabled]}" IsChecked="{Binding Mcp.IsRunning}"
                Command="{Binding Mcp.ToggleCommand}" VerticalAlignment="Center" />
      <TextBox Width="80" Text="{Binding Mcp.Port}" VerticalAlignment="Center" />
      <TextBlock Text="{Binding Mcp.Url}" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"
                 IsVisible="{Binding Mcp.IsRunning, FallbackValue=False}" />
    </StackPanel>

    <Button Content="{Binding Localization[Close]}" HorizontalAlignment="Right" Click="OnClose" />
  </StackPanel>
</Window>
